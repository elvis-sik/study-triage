FROM debian:trixie-slim

ARG ANKI_LAUNCHER_VERSION=25.09
ARG ANKI_LAUNCHER_URL=https://github.com/ankitects/anki/releases/download/${ANKI_LAUNCHER_VERSION}/anki-launcher-${ANKI_LAUNCHER_VERSION}-linux.tar.zst

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        fonts-dejavu-core \
        libasound2 \
        libdbus-1-3 \
        libegl1 \
        libevent-2.1-7t64 \
        libfontconfig1 \
        libfreetype6 \
        libglib2.0-0 \
        libgl1 \
        liblcms2-2 \
        libminizip1t64 \
        libnss3 \
        libopus0 \
        libsnappy1v5 \
        libtiff6 \
        libwebp7 \
        libwebpdemux2 \
        libwebpmux3 \
        libxcomposite1 \
        libxcb-cursor0 \
        libxdamage1 \
        libxfixes3 \
        libxcb-icccm4 \
        libxcb-image0 \
        libxcb-keysyms1 \
        libxcb-render-util0 \
        libxcb-shape0 \
        libxcb-xinerama0 \
        libxi6 \
        libxkbcommon-x11-0 \
        libxrandr2 \
        libxshmfence1 \
        libxtst6 \
        libxslt1.1 \
        python3 \
        tar \
        xauth \
        xdg-utils \
        xdotool \
        xvfb \
        zstd \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "${ANKI_LAUNCHER_URL}" -o /tmp/anki-launcher.tar.zst \
    && rm -rf /usr/local/share/anki \
    && mkdir -p /usr/local/share/anki /usr/local/bin \
    && tar --zstd -xf /tmp/anki-launcher.tar.zst -C /usr/local/share/anki --strip-components=1 \
    && ln -sf /usr/local/share/anki/anki /usr/local/bin/anki \
    && rm -f /tmp/anki-launcher.tar.zst

RUN printf '\n' | /usr/local/bin/anki >/tmp/anki-launcher-install.log 2>/tmp/anki-launcher-install.err \
    && test -x /root/.local/share/AnkiProgramFiles/.venv/bin/anki \
    && rm -rf /root/.cache/uv

ENV QT_QPA_PLATFORM=xcb
ENV QTWEBENGINE_CHROMIUM_FLAGS=--no-sandbox
ENV QTWEBENGINE_DISABLE_SANDBOX=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV DISPLAY=:99
ENV PYTHONPATH=/workspace/gui-agent-workbench/src:/workspace/anki-addon-workbench/src

WORKDIR /work

CMD ["sh", "-lc", "Xvfb :99 -screen 0 1280x1024x24 -nolisten tcp & xvfb_pid=$!; export DISPLAY=:99; python3 -m anki_addon_workbench smoke --anki-bin /root/.local/share/AnkiProgramFiles/.venv/bin/anki; status=$?; kill \"$xvfb_pid\" 2>/dev/null || true; exit \"$status\""]
